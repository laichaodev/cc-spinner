{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-desktop/main/tauri.conf.json",
  "productName": "CC Spinner",
  "version": "0.1.0",
  "identifier": "com.cc-spinner.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CC Spinner",
        "width": 900,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
